# =============================================================================
# AR Commerce Platform — Environment Variables
# Copy this to .env and fill in the values
# =============================================================================

# -- Supabase (required) ------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # service_role key (server-only, bypasses RLS)
SUPABASE_PUBLISHABLE_KEY=eyJ...          # anon/publishable key (client + server)

# -- Vite public env (client-side, prefixed with VITE_) -----------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# -- App URL (required for webhooks & OG images) ------------------------------
APP_URL=https://your-domain.com           # Public URL of the app
WEBHOOK_BASE_URL=https://your-domain.com  # Where AI providers send callbacks

# -- Vendor Webhook Secrets (required for marketplace webhook sync) ------------
SHOPIFY_CLIENT_SECRET=                    # Shopify webhook HMAC secret (from Shopify Admin → Notifications)
SHOPIFY_API_KEY=                          # Shopify Admin API key (for REST queries)
AMAZON_CLIENT_SECRET=                     # Amazon SP-API notification signing secret
DARAZ_CLIENT_SECRET=                      # Daraz Open Platform webhook signature key

# -- AI Providers (optional — enables 3D generation pipeline) -----------------
MESHY_API_KEY=                            # https://platform.meshy.ai
MESHY_API_URL=https://api.meshy.ai        # Default: https://api.meshy.ai
TRIPO_API_KEY=                            # https://platform.tripo3d.ai
TRIPO_API_URL=https://api.tripo3d.ai/v2/openapi  # Default

# -- Node (optional) ----------------------------------------------------------
NODE_ENV=development
